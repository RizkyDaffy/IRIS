{
  "name": "iris-core",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "kill-port 3001 && tsx watch --env-file=.env src/app.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node --env-file=.env dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^3.1.0",
    "@prisma/client": "^5.22.0",
    "amqplib": "^0.10.4",
    "argon2": "^0.41.1",
    "fastify": "^4.28.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^20.16.0",
    "kill-port": "^2.0.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
